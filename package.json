{
  "name": "reese-pi-workstation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Reproducible Reese Pi agent workstation setup, extensions, and health checks.",
  "scripts": {
    "typecheck:extensions": "tsc --noEmit -p tsconfig.json",
    "typecheck:verifier": "npm --prefix apps/verifier run typecheck",
    "typecheck:all": "npm run typecheck:extensions && npm run typecheck:verifier",
    "doctor": "bash scripts/doctor.sh"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.75.5",
    "@earendil-works/pi-coding-agent": "^0.75.5",
    "@earendil-works/pi-tui": "^0.75.5",
    "@types/node": "^22.0.0",
    "typebox": "^1.1.34",
    "typescript": "^5.6.0"
  }
}
