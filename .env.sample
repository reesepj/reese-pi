
ANTHROPIC_API_KEY=

OPENAI_API_KEY=

GEMINI_API_KEY=

OPENROUTER_API_KEY=

GROQ_API_KEY=

DEEPSEEK_API_KEY=

ELEVENLABS_API_KEY= # gitleaks:allow

FIRECRAWL_API_KEY= # gitleaks:allow

# Pi-to-Pi coms-net optional settings
# Localhost server auto-generates a token; LAN/remote use requires setting one.
PI_COMS_NET_AUTH_TOKEN=
PI_COMS_NET_SERVER_URL=
PI_COMS_NET_PROJECT=default
PI_COMS_NET_PORT=52965
PI_COMS_NET_HOST=127.0.0.1

# Browser Harness web/search tool
# Use this when launching an isolated Chrome with --remote-debugging-port=9222.
BU_CDP_URL=http://127.0.0.1:9222
